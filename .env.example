# =============================================================
# AMTEHI — Contoh Environment Variables
# Salin file ini menjadi:
#   - apps/api/.env
#   - apps/web/.env.local
# lalu isi nilainya. JANGAN commit file .env asli ke Git.
# =============================================================

# -------------------- apps/api/.env --------------------
NODE_ENV=development
PORT=3001

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # RAHASIA — hanya di backend, jangan di frontend

# Database (Prisma → Supabase Postgres connection string)
# Runtime serverless: Transaction Pooler (port 6543) + pgbouncer.
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-x-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Khusus `prisma migrate`: Session Pooler / direct (port 5432), TANPA pgbouncer.
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-x-region.pooler.supabase.com:5432/postgres

# App
FRONTEND_URL=http://localhost:3000     # produksi: https://<domain-web>
MAX_FILE_SIZE_MB=5                      # produksi Vercel: set 4 (batas body ~4.5MB)

# -------------------- apps/web/.env.local --------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Dev lokal: URL absolut. Produksi Vercel: kosongkan (axios pakai '/api' relatif).
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Produksi Vercel (proyek web): base URL API untuk rewrites (server-side, tanpa NEXT_PUBLIC_).
# API_URL=https://amtehi-api.vercel.app
