{
  "name": "amtehi",
  "version": "0.1.0",
  "private": true,
  "description": "AMTEHI — Amikom Temu Hilang. Platform lost & found digital kampus Amikom.",
  "author": "Faga | echofaga",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:web": "npm run dev --workspace=@amtehi/web",
    "dev:api": "npm run dev --workspace=@amtehi/api",
    "build:web": "npm run build --workspace=@amtehi/web",
    "build:api": "npm run build --workspace=@amtehi/api",
    "prisma:generate": "npm run prisma:generate --workspace=@amtehi/api",
    "prisma:migrate": "npm run prisma:migrate --workspace=@amtehi/api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "prisma@6.19.3": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
